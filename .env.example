# ============================================
# EventCulture - Variables d'environnement
# ============================================
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir TOUTES les valeurs ci-dessous
#   3. Ne JAMAIS commiter le fichier .env !
#
# SECURITE :
#   - Utiliser des mots de passe LONGS (min 16 caracteres)
#   - Generer JWT_SECRET avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   - En production : HTTPS obligatoire pour FRONTEND_URL et API_URL
# ============================================

# ==========================================
# ENVIRONNEMENT
# ==========================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ==========================================
# MYSQL
# ==========================================
MYSQL_ROOT_PASSWORD=CHANGER_MOT_DE_PASSE_ROOT_MINIMUM_16_CARACTERES
DB_NAME=actionculture
DB_USER=actionculture_user
DB_PASSWORD=CHANGER_MOT_DE_PASSE_USER_MINIMUM_16_CARACTERES
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql
DB_SYNC=false

# Pool de connexions
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ==========================================
# JWT - SECURITE
# ==========================================
JWT_SECRET=CHANGER_GENERER_AVEC_node_-e_console.log(require('crypto').randomBytes(64).toString('hex'))
JWT_EXPIRES_IN=24h

# ==========================================
# URLS
# ==========================================
# Developpement local SANS Docker (Vite dev = port 8080) :
# VITE_API_URL=http://localhost:3001/api
# FRONTEND_URL=http://localhost:8080
# API_URL=http://localhost:3001
# BASE_URL=http://localhost:3001

# Docker (dev ET prod) : TOUJOURS utiliser /api (chemin relatif)
# Le frontend nginx proxy /api/ vers le backend automatiquement
VITE_API_URL=/api
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001
BASE_URL=http://localhost:3001

# Production (decommenter et adapter, GARDER VITE_API_URL=/api) :
# FRONTEND_URL=https://actionculture.dz
# API_URL=https://api.actionculture.dz

# ==========================================
# REDIS
# ==========================================
USE_REDIS_MEMORY=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGER_MOT_DE_PASSE_REDIS_MINIMUM_16_CARACTERES

# ==========================================
# CLOUDINARY (requis en production)
# ==========================================
# Creer un compte sur https://cloudinary.com (gratuit jusqu'a 25GB)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# UPLOAD FICHIERS
# ==========================================
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_IMAGE_MAX_SIZE=5242880
UPLOAD_DOCUMENT_MAX_SIZE=10485760
UPLOAD_VIDEO_MAX_SIZE=104857600

# ==========================================
# EMAIL (requis en production)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=CHANGER_EMAIL
EMAIL_PASSWORD=CHANGER_MOT_DE_PASSE_EMAIL
EMAIL_FROM=noreply@actionculture.dz
EMAIL_PAUSED=true

# ==========================================
# SECURITE
# ==========================================
BCRYPT_ROUNDS=12

# ==========================================
# LOCALISATION
# ==========================================
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,ar,en,tz-ltn,tz-tfng
DEFAULT_TIMEZONE=Africa/Algiers

# ==========================================
# TACHES PLANIFIEES
# ==========================================
ENABLE_SCHEDULED_TASKS=true
ENABLE_AUDIT_LOGS=true
AUDIT_LOG_RETENTION_DAYS=90
ENABLE_METRICS=false

# ==========================================
# WEBSOCKET
# ==========================================
WEBSOCKET_ENABLED=true

# ==========================================
# ERROR MONITORING (Sentry)
# ==========================================
# Optionnel - laisser vide pour desactiver Sentry
# Obtenir le DSN depuis https://sentry.io
SENTRY_DSN=

# ==========================================
# PERFORMANCE (optionnel)
# ==========================================
# Seuil de requete lente en ms (logguee via Winston)
DB_SLOW_QUERY_MS=1000
