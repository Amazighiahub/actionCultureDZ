* text=auto eol=lf

# Force LF for critical files that break with CRLF
Makefile     text eol=lf
*.sh         text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.tsx        text eol=lf
*.css        text eol=lf
*.html       text eol=lf
*.md         text eol=lf
*.env*       text eol=lf
Dockerfile*  text eol=lf
.gitattributes text eol=lf

# Binary files (no conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
